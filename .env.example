# --- Backend (copy to backend/.env — or run `npm run setup` from repo root) ---
# Use SQLite for zero-setup local dev (no Docker). Set to false when using PostgreSQL.
USE_SQLITE=true

# PostgreSQL connection string (required when USE_SQLITE=false).
# Default matches docker-compose.yml in this repo (postgres / postgres / weather_app).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/weather_app

# OpenWeatherMap API key (required for live weather)
# https://openweathermap.org/api
OPENWEATHER_API_KEY=

# Optional: YouTube Data API v3 key for location-related video results
# https://console.cloud.google.com/apis/library/youtube.googleapis.com
YOUTUBE_API_KEY=

PORT=3001
# Use development while building locally so API errors are more descriptive in JSON responses
NODE_ENV=development
# Comma-separated allowed origins for CORS
FRONTEND_ORIGIN=http://localhost:5173

# --- Frontend (optional: copy to frontend/.env) ---
# Your name appears in the app footer for assessors — see also frontend/.env.example
# VITE_APPLICANT_NAME=Your Full Name
#
# Defaults to "/api" so the Vite dev proxy can forward to the backend.
# For production builds served separately, set the full API base:
# VITE_API_URL=https://your-api.example.com/api
